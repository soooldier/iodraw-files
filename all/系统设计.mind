{"root":{"data":{"id":"dhsk1tlkh7c0","created":1776137087210,"text":"系统设计"},"children":[{"data":{"id":"dhsnou3q2s80","created":1776147354013,"text":"概述"},"children":[{"data":{"id":"dhsnovv084o0","created":1776147357840,"text":"分类"},"children":[{"data":{"id":"dhsnp0sg2mo0","created":1776147368569,"text":"网络设计"},"children":[]},{"data":{"id":"dhsnp260ndk0","created":1776147371566,"text":"代码设计"},"children":[{"data":{"id":"dhsnq5efscg0","created":1776147456970,"text":"结构化设计"},"children":[]},{"data":{"id":"dhsnq9hjjrc0","created":1776147465865,"text":"面向对象设计"},"children":[]}]},{"data":{"id":"dhsnp3r8w680","created":1776147375027,"text":"输入设计"},"children":[]},{"data":{"id":"dhsnp4ne5gw0","created":1776147376970,"text":"输出设计"},"children":[]},{"data":{"id":"dhsnp6p9c1k0","created":1776147381437,"text":"数据存储设计","layout_right_offset":{"x":-10,"y":17}},"children":[]},{"data":{"id":"dhsnplpu2xs0","created":1776147414123,"text":"用户界面设计"},"children":[]},{"data":{"id":"dhsnpubkl880","created":1776147432852,"text":"安全性和可靠性设计"},"children":[]},{"data":{"id":"dhsnpcb0k7k0","created":1776147393636,"text":"处理流程设计","layout_right_offset":{"x":-7,"y":-15}},"children":[{"data":{"id":"dhsnqq3un3k0","created":1776147502042,"text":"目标"},"children":[{"data":{"id":"dhso1dbalm00","created":1776148336200,"text":"设计系统模块及他们之间的相互关系，并设计出每个模块内部的功能和处理过程"},"children":[]}]},{"data":{"id":"dhso1it2y4o0","created":1776148348159,"text":"核心概念"},"children":[{"data":{"id":"dhso1ks4dzk0","created":1776148352455,"text":"流程"},"children":[{"data":{"id":"dhso26ss77c0","created":1776148400384,"text":"定义：一组将输入转化为输出的相互关联或相互作用的活动"},"children":[]},{"data":{"id":"dhso2vpsrio0","created":1776148454623,"text":"基本要素"},"children":[{"data":{"id":"dhso2xfyilk0","created":1776148458382,"text":"输入资源"},"children":[]},{"data":{"id":"dhso2z8mvi80","created":1776148462292,"text":"活动"},"children":[]},{"data":{"id":"dhso30h48dc0","created":1776148464982,"text":"活动的相互作用（结构）"},"children":[]},{"data":{"id":"dhso34c9ob40","created":1776148473396,"text":"输出结果"},"children":[]},{"data":{"id":"dhso36idzc80","created":1776148478120,"text":"用户"},"children":[]},{"data":{"id":"dhso3w5xajc0","created":1776148533962,"text":"价值"},"children":[]}]}]},{"data":{"id":"dhso1ltxly00","created":1776148354741,"text":"工作流"},"children":[]},{"data":{"id":"dhso1nnhsaw0","created":1776148358705,"text":"活动及其所有者"},"children":[]},{"data":{"id":"dhso1r2xdn40","created":1776148366169,"text":"工作项"},"children":[]}]}]},{"data":{"id":"dhso51g5pio0","created":1776148623829,"text":"流程设计工具"},"children":[{"data":{"id":"dhso57a5pj40","created":1776148636527,"text":"图形工具"},"children":[{"data":{"id":"dhso5jwy5o00","created":1776148664027,"text":"程序流程图（PFD）"},"children":[]},{"data":{"id":"dhso5s0hfls0","created":1776148681655,"text":"NS图（盒图）"},"children":[]},{"data":{"id":"dhso62a6uuw0","created":1776148704009,"text":"IPO图"},"children":[]},{"data":{"id":"dhso64xtlcw0","created":1776148709792,"text":"问题分析图（PAD）"},"children":[]},{"data":{"id":"dhso6bb13ls0","created":1776148723651,"text":"判定树"},"children":[]}]},{"data":{"id":"dhso5b4dfmo0","created":1776148644884,"text":"表格工具"},"children":[{"data":{"id":"dhso6smwq480","created":1776148761375,"text":"判定表"},"children":[]}]},{"data":{"id":"dhso5dzdti00","created":1776148651113,"text":"语言工具"},"children":[{"data":{"id":"dhso6y807800","created":1776148773534,"text":"过程语言设计（PDL）"},"children":[]}]}]}]}]},{"data":{"id":"dhsok1v8bc80","created":1776149800203,"text":"面向对象设计"},"children":[{"data":{"id":"dhsol06g0pc0","created":1776149874892,"text":"设计类分类"},"children":[{"data":{"id":"dhsol3d9dpc0","created":1776149881834,"text":"实体类"},"children":[{"data":{"id":"dhsoldef3zs0","created":1776149903672,"text":"映射需求中的实体，保持需永久存储的信息（比如学员类，课程类）"},"children":[]}]},{"data":{"id":"dhsol4d91ko0","created":1776149884010,"text":"控制类"},"children":[{"data":{"id":"dhsombs8cv40","created":1776149978518,"text":"控制用例工作，对用例特有的控制行为建模，系统执行时产生，结束后消亡（比如身份验证器）"},"children":[]}]},{"data":{"id":"dhsol6nngyw0","created":1776149888993,"text":"边界类"},"children":[{"data":{"id":"dhson6xk3z40","created":1776150046320,"text":"封装用例内外流动的信息或数据流，处于系统与外界交界处（比如通信协议、打印机接口、报表等）"},"children":[]}]}]},{"data":{"id":"dhsphp89ne80","created":1776152437075,"text":"设计原则"},"children":[{"data":{"id":"dhsphw173j40","created":1776152451885,"text":"单一职责（S）"},"children":[{"data":{"id":"dhspn90eus80","created":1776152871956,"text":"一个类有且只有一个引起它变化的原因（只有一个设计目的）"},"children":[]}]},{"data":{"id":"dhsphzx1ql40","created":1776152460341,"text":"开闭原则（O）"},"children":[{"data":{"id":"dhspnibniug0","created":1776152892227,"text":"软件实体应该对扩展开放，对修改关闭（添加新功能时应该通过新增代码来实现，不能去修改以前的代码）"},"children":[]}]},{"data":{"id":"dhspi3kqjhk0","created":1776152468304,"text":"李氏替换原则（L）"},"children":[{"data":{"id":"dhspogbrc7k0","created":1776152966244,"text":"子类必须能够完全替换其父类，而不改变程序的正确性"},"children":[]}]},{"data":{"id":"dhspiier2280","created":1776152500593,"text":"接口隔离原则（I）"},"children":[{"data":{"id":"dhsrh9f67o00","created":1776158044884,"text":"客户端不应该被强迫依赖它用不到的接口方法，提倡将庞大臃肿的接口拆分成更小、更具体的接口，让客户端只需要知道它真正关心的方法"},"children":[]}]},{"data":{"id":"dhspivu25w80","created":1776152529817,"text":"依赖倒置原则（D）"},"children":[{"data":{"id":"dhsppgiqxwg0","created":1776153045031,"text":"高层模块不应该依赖低层模块，两者都应依赖抽象。抽象不依赖细节，细节依赖抽象。"},"children":[]}]},{"data":{"id":"dhspj025hw80","created":1776152539014,"text":"组合/聚合复用原则"},"children":[{"data":{"id":"dhsppod4nko0","created":1776153062105,"text":"通过组合或聚合复用已有对象，优先使用对象组合（has-a），而非继承（is-a）"},"children":[]}]},{"data":{"id":"dhspj4crjug0","created":1776152548363,"text":"最少知识原则（迪米特法则）"},"children":[{"data":{"id":"dhspr6zjdi00","created":1776153181006,"text":"一个对象应对其它对象保持最少的了解"},"children":[]}]}]}]},{"data":{"id":"dhsrn7sutew0","created":1776158511542,"text":"结构化设计（SD）"},"children":[{"data":{"id":"dhss1wai7vk0","created":1776159661951,"text":"概念"},"children":[{"data":{"id":"dhss1y3xkf40","created":1776159665907,"text":"面向“数据流”的方法，以数据流图和数据字典等文档为基础"},"children":[]}]},{"data":{"id":"dhss3li0y540","created":1776159795189,"text":"四个活动"},"children":[{"data":{"id":"dhss3o9s66o0","created":1776159801221,"text":"数据设计"},"children":[]},{"data":{"id":"dhss3puozns0","created":1776159804662,"text":"软件结构设计"},"children":[]},{"data":{"id":"dhss3w6kzpk0","created":1776159818442,"text":"人机界面设计/接口设计"},"children":[]},{"data":{"id":"dhss3ztfyoo0","created":1776159826354,"text":"过程设计"},"children":[]}]},{"data":{"id":"dhss5g8mcsg0","created":1776159940465,"text":"模块划分原则"},"children":[{"data":{"id":"dhss5km2n7k0","created":1776159949985,"text":"大小适中"},"children":[]},{"data":{"id":"dhss5ngsa3k0","created":1776159956196,"text":"扇入扇出合理"},"children":[]},{"data":{"id":"dhss5wykqu00","created":1776159976863,"text":"深度和宽度适中"},"children":[]},{"data":{"id":"dhss618yd5s0","created":1776159986197,"text":"信息隐蔽"},"children":[]}]},{"data":{"id":"dhss8wp7we80","created":1776160211389,"text":"模块耦合分类（记忆：非鼠标控制外公勒）"},"children":[{"data":{"id":"dhss92p4sgo0","created":1776160224445,"text":"内容耦合（最高）"},"children":[]},{"data":{"id":"dhss961jphc0","created":1776160231726,"text":"公共耦合"},"children":[]},{"data":{"id":"dhss98jal4w0","created":1776160237153,"text":"外部耦合"},"children":[]},{"data":{"id":"dhss99pse540","created":1776160239722,"text":"控制耦合"},"children":[]},{"data":{"id":"dhss9bjekf40","created":1776160243690,"text":"标记耦合"},"children":[]},{"data":{"id":"dhss9d65fmo0","created":1776160247242,"text":"数据耦合"},"children":[]},{"data":{"id":"dhss9f3h4k00","created":1776160251434,"text":"非直接耦合（最低）"},"children":[]}]},{"data":{"id":"dhssch1irug0","created":1776160490761,"text":"模块内聚分类（记忆：公孙铜锅涮罗欧）"},"children":[{"data":{"id":"dhsscj72srk0","created":1776160495451,"text":"功能内聚（高）"},"children":[]},{"data":{"id":"dhsscpu4psw0","created":1776160509906,"text":"顺序内聚"},"children":[]},{"data":{"id":"dhsscs8jutk0","created":1776160515131,"text":"通信内聚"},"children":[]},{"data":{"id":"dhsscudlouw0","created":1776160519790,"text":"过程内聚"},"children":[]},{"data":{"id":"dhsscwsu2ao0","created":1776160525065,"text":"瞬时内聚"},"children":[]},{"data":{"id":"dhssd0d6omw0","created":1776160532826,"text":"逻辑内聚"},"children":[]},{"data":{"id":"dhssd2biby00","created":1776160537078,"text":"偶然内聚"},"children":[]}]}]},{"data":{"id":"dhssers4vjs0","created":1776160670867,"text":"设计模式"},"children":[{"data":{"id":"dhssfa8nnl40","created":1776160711048,"text":"创建模式（记忆：工厂抽象建造者，单例原型巧构成）"},"children":[{"data":{"id":"dhssffvu0yo0","created":1776160723333,"text":"工厂方法"},"children":[]},{"data":{"id":"dhssfhupvq00","created":1776160727619,"text":"抽象工厂"},"children":[]},{"data":{"id":"dhssfjor2co0","created":1776160731612,"text":"生成器"},"children":[{"data":{"id":"dhtil98gfjc0","created":1776234527902,"text":"将一个复杂对象的构建与其表示分离，使同样的构建过程可以创建不同的表示"},"children":[]}]},{"data":{"id":"dhssflc7xc80","created":1776160735208,"text":"原型"},"children":[{"data":{"id":"dhtim0cjo200","created":1776234586922,"text":"通过复制现有对象来创建新对象"},"children":[]}]},{"data":{"id":"dhssfmlt18w0","created":1776160737964,"text":"单例"},"children":[]}]},{"data":{"id":"dhssfbu165c0","created":1776160714517,"text":"结构模式（记忆：试桥组装外享代）"},"children":[{"data":{"id":"dhssgjvr21c0","created":1776160810400,"text":"适配器"},"children":[{"data":{"id":"dhtinbl74zc0","created":1776234689754,"text":"将一个类的接口转换为客户希望的另一个接口，使原本的不兼容可以一起工作"},"children":[]}]},{"data":{"id":"dhssgp6z7kw0","created":1776160821962,"text":"桥接"},"children":[{"data":{"id":"dhtinqy0ds00","created":1776234723180,"text":"将抽象与实现分离，使他们可以独立变化"},"children":[]}]},{"data":{"id":"dhssgqpfa4w0","created":1776160825254,"text":"组合"},"children":[{"data":{"id":"dhtiuzjq61s0","created":1776235290457,"text":"将对象组合成“部分-整体”的层次，使客户可以统一处理单个对象和组合对象"},"children":[]}]},{"data":{"id":"dhssgrg7ihk0","created":1776160826874,"text":"装饰"},"children":[{"data":{"id":"dhtivq9hc6g0","created":1776235348611,"text":"动态给对象添加职责而不改变其接口"},"children":[]}]},{"data":{"id":"dhssgsl84280","created":1776160829354,"text":"外观"},"children":[{"data":{"id":"dhtivys37xs0","created":1776235367150,"text":"为系统中的接口提供一个更容易使用的高层接口"},"children":[]}]},{"data":{"id":"dhssgu35f8g0","created":1776160832615,"text":"享元"},"children":[{"data":{"id":"dhtiwd69u2g0","created":1776235398482,"text":"通过共享技术来支持大量对象的复用"},"children":[]}]},{"data":{"id":"dhssgyjx0hs0","created":1776160842336,"text":"代理"},"children":[{"data":{"id":"dhtiwpf7y3k0","created":1776235425145,"text":"为另一个对象提供一个代理或占位符以控制对它的访问"},"children":[]}]}]},{"data":{"id":"dhssfczwhsw0","created":1776160717049,"text":"行为模式（记忆：观察命令责任链，迭代模版状态变，中介策略备忘录，解释访问都包含）"},"children":[{"data":{"id":"dhssh30081c0","created":1776160852016,"text":"责任链"},"children":[{"data":{"id":"dhtixgkz1go0","created":1776235484266,"text":"使多个对象都有机会处理请求，避免发送者和接收者耦合"},"children":[]}]},{"data":{"id":"dhssh5do09c0","created":1776160857195,"text":"命令"},"children":[]},{"data":{"id":"dhssh6gdg2o0","created":1776160859536,"text":"迭代器"},"children":[]},{"data":{"id":"dhssh8dmxbs0","created":1776160863724,"text":"中介者"},"children":[]},{"data":{"id":"dhssh9uf93k0","created":1776160866916,"text":"备忘录"},"children":[]},{"data":{"id":"dhsshav2ye80","created":1776160869132,"text":"观察者"},"children":[]},{"data":{"id":"dhsshc239n40","created":1776160871733,"text":"状态"},"children":[]},{"data":{"id":"dhsshcusl7c0","created":1776160873468,"text":"策略"},"children":[]},{"data":{"id":"dhssheituk00","created":1776160877098,"text":"模版方法"},"children":[]},{"data":{"id":"dhsshfsg19c0","created":1776160879857,"text":"访问者"},"children":[]},{"data":{"id":"dhsshh62g5c0","created":1776160882857,"text":"解释器"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}