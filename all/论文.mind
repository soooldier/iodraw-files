:[]}]},{"data":{"id":"dii1ypmplu00","created":1778726622374,"text":"可靠性测试","font-size":24},"children":[]}]},{"data":{"id":"dii1z4vuvgw0","created":1778726655579,"text":"安全测试，sqlmap、zap","font-size":24},"children":[{"data":{"id":"dii1za4evvc0","created":1778726666980,"text":"程序本身安全","font-size":24},"children":[]},{"data":{"id":"dii1zcxqigo0","created":1778726673107,"text":"数据安全","font-size":24},"children":[]}]},{"data":{"id":"dii1zwzo2yg0","created":1778726716760,"text":"兼容性测试","font-size":24},"children":[{"data":{"id":"dii201ebhe80","created":1778726726353,"text":"不同操作系统平台及版本","font-size":24},"children":[]},{"data":{"id":"dii205qfp400","created":1778726735792,"text":"自身前后兼容","font-size":24},"children":[]},{"data":{"id":"dii20bw38o00","created":1778726749195,"text":"web特有的各类浏览器兼容","font-size":24},"children":[]}]},{"data":{"id":"dii20okvbps0","created":1778726776815,"text":"界面测试","font-size":24},"children":[]},{"data":{"id":"dii20y3lpr40","created":1778726797539,"text":"易用性测试","font-size":24},"children":[]},{"data":{"id":"dii2118s5og0","created":1778726804382,"text":"稳定性测试","font-size":24},"children":[{"data":{"id":"dii2192vsyg0","created":1778726821440,"text":"长时间运行软件，观察是否正常","font-size":24},"children":[]}]}]},{"data":{"id":"dii2a68dem80","created":1778727520519,"text":"WHX模型","font-size":24},"children":[{"data":{"id":"dii2aej8hbk0","created":1778727538590,"text":"W模型，在V模型上发展，测试与开发同步《同步》","font-size":24},"children":[]},{"data":{"id":"dii2amyuftk0","created":1778727556948,"text":"H模型，测试活动独立《独立》","font-size":24},"children":[]},{"data":{"id":"dii2atyps9s0","created":1778727572177,"text":"X模型，针对单独程序片段进行编码和测试，频繁\n交错集成《交错》","layout_left_offset":{"x":1,"y":0},"font-size":24},"children":[]}]}]},{"data":{"id":"dilkrbxlfq00","created":1779084324967,"text":"服务网格","expandState":"expand","font-size":24},"children":[{"data":{"id":"dilkvtbwy8w0","created":1779084676295,"text":"选型：Istio vs Linkerd","layout_left_offset":{"x":-51,"y":4},"font-size":24},"children":[{"data":{"id":"dilkw3v6dh40","created":1779084699227,"text":"istio：功能完备、高安全需求","font-size":24},"children":[]},{"data":{"id":"dilkw77sxz40","created":1779084706521,"text":"Linkerd：极简零配置，开箱即用、性能极致、生态整合稍弱","font-size":24},"children":[]}]},{"data":{"id":"dilkz6g23js0","created":1779084939936,"text":"Istio","font-size":24},"children":[{"data":{"id":"dilkz7sl8zk0","created":1779084942870,"text":"流量治理","font-size":24},"children":[{"data":{"id":"dill1m6vrfs0","created":1779085130938,"text":"流量路由（到哪个服务，不关心服务状态）：VirtualService","font-size":24},"children":[]},{"data":{"id":"dilkzgn2pu80","created":1779084962128,"text":"负载均衡（怎么分配）：DestinationRule\n实际一般给不同版本的pod打上标签再配合\nDestinationRule的subset配置进行分发。","font-size":24},"children":[{"data":{"id":"dill09z6m800","created":1779085025987,"text":"round-robin：依次循环，适用于实例之间算力\n相当，无状态服务","layout_left_offset":{"x":14,"y":-7},"font-size":24},"children":[]},{"data":{"id":"dill0fs9qww0","created":1779085038629,"text":"least-conn：最小请求，适用于处理请求之间耗时差异大","font-size":24},"children":[]}]},{"data":{"id":"dilkzzw5vyo0","created":1779085004036,"text":"流量控制","font-size":24},"children":[{"data":{"id":"dill2gjdbc80","created":1779085196996,"text":"限流","font-size":24},"children":[{"data":{"id":"dill4s95wug0","created":1779085379229,"text":"全局限流：EnvoyFilter + 单独部署\n的ratelimit服务go+Redis","layout_left_offset":{"x":-1,"y":-3},"font-size":24},"children":[]},{"data":{"id":"dill4v37ug00","created":1779085385400,"text":"本地限流","font-size":24},"children":[]}]},{"data":{"id":"dill2hzxz6w0","created":1779085200175,"text":"复制","font-size":24},"children":[]}]},{"data":{"id":"dill062vug80","created":1779085017503,"text":"流量弹性","expandState":"expand","font-size":24},"children":[{"data":{"id":"dill21x8k340","created":1779085165183,"text":"超时：无限制等待","font-size":24},"children":[]},{"data":{"id":"dill24f5kls0","created":1779085170620,"text":"熔断：代理主动监控服务状态，根据配\n置标记不健康，指定时间内被隔离，不\n接受流量","font-size":24},"children":[]},{"data":{"id":"dill25un6340","created":1779085173733,"text":"重试：瞬时故障，注意幂等保护","font-size":24},"children":[]}]}]},{"data":{"id":"dilkz9q66kw0","created":1779084947078,"text":"可观测性：固定采样 -> 自适配采样 -> 错误优先采样\n错误优先采样：部署OpenTelemetry Collector","font-size":24},"children":[{"data":{"id":"dillahhh3kw0","created":1779085825972,"text":"Metrics：宏观出问题了","font-size":24},"children":[{"data":{"id":"dillaqa29hk0","created":1779085845115,"text":"Prometheus+Grafana","font-size":24},"children":[]}]},{"data":{"id":"dill65tpzow0","created":1779085487134,"text":"Tracing：微观哪里出了问题","font-size":24},"children":[{"data":{"id":"dill6myivvc0","created":1779085524430,"text":"Jaeger","font-size":24},"children":[]}]},{"data":{"id":"dill6dg2bqg0","created":1779085503723,"text":"Logging：事件细节，为什么出了问题","font-size":24},"children":[{"data":{"id":"dill6lbjh340","created":1779085520863,"text":"Loki","font-size":24},"children":[]}]}]},{"data":{"id":"dilkzemtako0","created":1779084957758,"text":"安全性","font-size":24},"children":[{"data":{"id":"dill72ex49s0","created":1779085558073,"text":"mTLS：服务间通信全加密，防止中间人劫持","font-size":24},"children":[]},{"data":{"id":"dill74gotj40","created":1779085562534,"text":"JWT：网格层验证，尽早拒绝非法请求。\n后端服务专注业务，在配置JWTRule中指定claim中指定字段","layout_left_offset":{"x":-64,"y":20},"font-size":24},"children":[]}]},{"data":{"id":"dilll3lh0kw0","created":1779086657744,"text":"举例","font-size":24},"children":[{"data":{"id":"dilll5agd4w0","created":1779086661432,"text":"限流","font-size":24},"children":[{"data":{"id":"dilllnap09k0","created":1779086700628,"text":"1. 单用户令牌桶\n2. 整个服务限流，返回429","layout_left_offset":{"x":-80,"y":11},"font-size":24},"children":[]}]},{"data":{"id":"dilll7xpxxs0","created":1779086667192,"text":"可观测性","font-size":24},"children":[]},{"data":{"id":"dillld9zbwo0","created":1779086678817,"text":"安全性","font-size":24},"children":[]},{"data":{"id":"dilmm6qjzy00","created":1779089564056,"text":"踩坑","expandState":"expand","font-size":24},"children":[{"data":{"id":"dilmmap3nog0","created":1779089572675,"text":"滚动更新，优雅启动\n1. 增加terminationDrainDuration时间\n2. 服务本身正确处理SIGTERM信号","layout_left_offset":{"x":-20,"y":76},"expandState":"expand","font-size":24},"children":[]},{"data":{"id":"dilmmvtvqm80","created":1779089618677,"text":"pod无法拉取：业务容器先于sidecar启动，\n配置holdApplicationUntilProxyStarts:true","layout_left_offset":{"x":-7,"y":-153},"font-size":24},"children":[]}]}]}]}]},{"data":{"id":"dilvnsm5gw80","created":1779115080032,"text":"系统可靠性"},"children":[{"data":{"id":"dilvo4x5zp40","created":1779115106820,"text":"分类"},"children":[{"data":{"id":"dilvo6v5q6w0","created":1779115111052,"text":"容错设计"},"children":[{"data":{"id":"dilvp0kblds0","created":1779115175700,"text":"恢复块设计：恢复块含功能相同但设计不同的程序块，故障时切换"},"children":[]},{"data":{"id":"dilvp3gq7z40","created":1779115182013,"text":"N版本设计：多个版本，同样输入采用多数表决方式，各版本使用的设计算法、编程语言、测试方等确保相互独立"},"children":[]},{"data":{"id":"dilvp4pd4yw0","created":1779115184712,"text":"冗余设计：主系统外设计备用软件模块，主模块故障时切换以提高可靠性"},"children":[]}]},{"data":{"id":"dilvobqsiy00","created":1779115121672,"text":"检错技术"},"children":[{"data":{"id":"dilvsqpfpy80","created":1779115467698,"text":"设置监测点和检测机制，通过检测返回结果等方式检测软件运行状态，发现故障后立即停止软件并告警"},"children":[]}]},{"data":{"id":"dilvomn72e80","created":1779115145399,"text":"降低复杂度设计"},"children":[{"data":{"id":"dilvu364kdc0","created":1779115573193,"text":"包括模块内部的复杂度和模块间复杂度，过高复杂度是软件缺陷根源。通过简化软件结构，优化数据流等方式降低复杂度以提高可靠性"},"children":[]}]},{"data":{"id":"dilvoorw72g0","created":1779115150037,"text":"系统配置技术"},"children":[{"data":{"id":"dilvvdayu5c0","created":1779115673618,"text":"双机热备：使用主备服务器模式，通过检测“心跳”来进行主备切换"},"children":[]},{"data":{"id":"dilvvns2qu00","created":1779115696420,"text":"服务集群：多台服务器组成单一系统，某台服务器故障时其他服务器自动接管"},"children":[]}]}]},{"data":{"id":"dilvzsvdnso0","created":1779116020960,"text":"度量"},"children":[{"data":{"id":"dilvzxvf2zk0","created":1779116031847,"text":"MTBF：平均故障间隔时间\nMean Time Between Failure"},"children":[]},{"data":{"id":"dilw0htelu80","created":1779116075261,"text":"MTTF：平均故障时间\nMean Time To Failure\n系统从开始使用到出现故障的平\n均时间，不包括检测和修复","layout_left_offset":{"x":-53,"y":0}},"children":[]},{"data":{"id":"dilw1pd90z40","created":1779116170062,"text":"MTTR：平均故障修复时间"},"children":[]},{"data":{"id":"dilw1uiriu80","created":1779116181279,"text":"MTTA：平均故障响应时间\nAcknownledge"},"children":[]},{"data":{"id":"dilw2ig2qp40","created":1779116233360,"text":"MTTD：平均故障发现时间\nDetection"},"children":[]}]},{"data":{"id":"dilw5x7qxq80","created":1779116500600,"text":"影响可靠性的因素\n还闺内发钱","layout_left_offset":{"x":-37,"y":23}},"children":[{"data":{"id":"dilw6fzh2cw0","created":1779116541459,"text":"运行环境（剖面）"},"children":[]},{"data":{"id":"dilw6jqxvag0","created":1779116549650,"text":"软件规模"},"children":[]},{"data":{"id":"dilw6n40k540","created":1779116556971,"text":"软件内部结构"},"children":[]},{"data":{"id":"dilw6sh0fxs0","created":1779116568641,"text":"软件开发方法和开发环境"},"children":[]},{"data":{"id":"dilw6w2sdeg0","created":1779116576488,"text":"可靠性投入的规模"},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}