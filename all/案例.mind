{"root":{"data":{"id":"di5b7esnleg0","created":1777432414619,"text":"案例"},"children":[{"data":{"id":"di5b7k8u72o0","created":1777432426482,"text":"需求分析"},"children":[{"data":{"id":"di5fg1pu0d40","created":1777444375868,"text":"把需求获取阶段得到的零散需求进行整合，并对冲突\n进行沟通协调，把内容和相关干系人达成共识"},"children":[]},{"data":{"id":"di5fiz7vc2o0","created":1777444605520,"text":"1. 建立需求分析模型\n2. 创建用户界面原型\n3. 分析需求可行性\n4. 确定需求优先级\n5. 创建数据字典\n6. 使用QFD（Quality Function Deployment）","layout_right_offset":{"x":17,"y":57}},"children":[]}]},{"data":{"id":"di5idyex97s0","created":1777452675279,"text":"软件架构设计"},"children":[{"data":{"id":"di5iekmqbzc0","created":1777452723640,"text":"质量属性"},"children":[{"data":{"id":"di5if0vkego0","created":1777452759003,"text":"质量属性效用树"},"children":[]},{"data":{"id":"di5ife4xkfs0","created":1777452787867,"text":"质量属性判定"},"children":[]}]},{"data":{"id":"di5iem3jiww0","created":1777452726833,"text":"架构风格"},"children":[{"data":{"id":"di5in8vylww0","created":1777453403354,"text":"分支主题"},"children":[]}]},{"data":{"id":"di5ien9u6zs0","created":1777452729391,"text":"典型架构"},"children":[]},{"data":{"id":"di5ietqqwrk0","created":1777452743474,"text":"架构评估"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}