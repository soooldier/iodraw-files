{"root":{"data":{"id":"di5b7esnleg0","created":1777432414619,"text":"案例"},"children":[{"data":{"id":"di5b7k8u72o0","created":1777432426482,"text":"需求分析"},"children":[{"data":{"id":"di5fg1pu0d40","created":1777444375868,"text":"定义：把需求收集得到的零散需求进行整合，并对冲突\n进行沟通协调，把内容和相关干系人达成共识"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}