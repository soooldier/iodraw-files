{"root":{"data":{"id":"dhueh4fo7yo0","created":1776324479514,"text":"系统架构设计"},"children":[{"data":{"id":"dhueiaqjis80","created":1776324571596,"text":"架构4+1（罗凯进五常）"},"children":[{"data":{"id":"dhueif38mj40","created":1776324581071,"text":"逻辑视图"},"children":[]},{"data":{"id":"dhueimtnvrc0","created":1776324597907,"text":"开发视图"},"children":[]},{"data":{"id":"dhueip4a5k00","created":1776324602902,"text":"进程视图"},"children":[]},{"data":{"id":"dhueirhzv0w0","created":1776324608085,"text":"物理视图"},"children":[]},{"data":{"id":"dhueiufba8w0","created":1776324614454,"text":"+1 场景"},"children":[]}]},{"data":{"id":"dhuejpnhnk80","created":1776324682428,"text":"RUP和UML的4+1（落实进步用）"},"children":[{"data":{"id":"dhuejvl9vyg0","created":1776324695355,"text":"逻辑视图"},"children":[]},{"data":{"id":"dhuejxccaj40","created":1776324699168,"text":"实现视图"},"children":[]},{"data":{"id":"dhuek14sha00","created":1776324707419,"text":"进程视图"},"children":[]},{"data":{"id":"dhuek6fuxo00","created":1776324718972,"text":"部署视图"},"children":[]},{"data":{"id":"dhuek81xcwg0","created":1776324722483,"text":"+1 用例"},"children":[]}]},{"data":{"id":"dhuekdbhctk0","created":1776324733945,"text":"ABSD中4+1（落实进配）"},"children":[{"data":{"id":"dhuekkizvy80","created":1776324749636,"text":"逻辑视图"},"children":[]},{"data":{"id":"dhueknl021s0","created":1776324756288,"text":"实现视图"},"children":[]},{"data":{"id":"dhuekoxf5so0","created":1776324759216,"text":"进程视图"},"children":[]},{"data":{"id":"dhuekqf5vao0","created":1776324762465,"text":"配置视图"},"children":[]},{"data":{"id":"dhuekrhce800","created":1776324764774,"text":"+1 用例"},"children":[]}]},{"data":{"id":"dhuemfy1oug0","created":1776324896391,"text":" ABSD"},"children":[{"data":{"id":"dhuenrn7v1c0","created":1776325000222,"text":"基于体系结构的软件设计"},"children":[{"data":{"id":"dhuer5dc0ao0","created":1776325265191,"text":"由构成体系结构的商业、质量和功能需求的组合驱动"},"children":[]},{"data":{"id":"dhueruf4d3k0","created":1776325319719,"text":"3个基础"},"children":[{"data":{"id":"dhuerwrmey80","created":1776325324829,"text":"功能分解"},"children":[]},{"data":{"id":"dhues1ijlrs0","created":1776325335163,"text":"通过选择体系结构风格来实现质量和商业需求"},"children":[]},{"data":{"id":"dhues9yypts0","created":1776325353571,"text":"使用软件模版"},"children":[]}]}]},{"data":{"id":"dhuevt5kjz40","created":1776325630421,"text":"基于体系结构的开发"},"children":[{"data":{"id":"dhuew5032vc0","created":1776325656211,"text":"子过程（许设温敷试验）"},"children":[{"data":{"id":"dhuewjlv0co0","created":1776325688003,"text":"需求"},"children":[{"data":{"id":"dhuex592fdk0","created":1776325735118,"text":"系统质量目标"},"children":[]},{"data":{"id":"dhuex8d462g0","created":1776325741894,"text":"商业目标"},"children":[]},{"data":{"id":"dhuexb590w00","created":1776325747948,"text":"开发人员商业目标"},"children":[]}]},{"data":{"id":"dhuewl9mlio0","created":1776325691617,"text":"设计"},"children":[]},{"data":{"id":"dhuewmidp5s0","created":1776325694323,"text":"文档化"},"children":[{"data":{"id":"dhuey75rj6g0","created":1776325817636,"text":"输出"},"children":[{"data":{"id":"dhuey82fim00","created":1776325819612,"text":"体系结构规格说明书"},"children":[]},{"data":{"id":"dhueyfm5bd40","created":1776325836041,"text":"测试质量设计说明书"},"children":[]}]}]},{"data":{"id":"dhuewnmpg0g0","created":1776325696761,"text":"复审"},"children":[]},{"data":{"id":"dhuewr0m3so0","created":1776325704132,"text":"实现"},"children":[]},{"data":{"id":"dhuexvlaa6o0","created":1776325792454,"text":"演化"},"children":[{"data":{"id":"dhuezj3v6iw0","created":1776325922007,"text":"需求变化归类"},"children":[]},{"data":{"id":"dhuezoiysrs0","created":1776325933804,"text":"制定演化计划"},"children":[]},{"data":{"id":"dhuf03g6zt40","created":1776325966288,"text":"修改/增加/扇出构件"},"children":[]},{"data":{"id":"dhuf07426qo0","created":1776325974262,"text":"更新构件的相互作用"},"children":[]},{"data":{"id":"dhuf0by6ceg0","created":1776325984790,"text":"构件组装与测试"},"children":[]},{"data":{"id":"dhuf0f0sth40","created":1776325991479,"text":"技术评审"},"children":[]}]}]}]}]},{"data":{"id":"dhuf92m8rco0","created":1776326669755,"text":"软件架构风格"},"children":[{"data":{"id":"dhuf96cbrqg0","created":1776326677862,"text":"概念"},"children":[{"data":{"id":"dhuf97jof1c0","created":1776326680484,"text":"定义一个词汇表和一组约束，词汇表包含构件和连接件。反应了众多系统所共有的结构和语义特性，并指导如何将各个模块和子系统有效地组成一个完整的系统。"},"children":[]}]},{"data":{"id":"dhufbg23h1k0","created":1776326855740,"text":"分类"},"children":[{"data":{"id":"dhufrtfhewg0","created":1776328138674,"text":"数据流风格","expandState":"expand"},"children":[{"data":{"id":"dhufbgxr0ig0","created":1776326857654,"text":"批处理风格"},"children":[{"data":{"id":"dhufcfnq2h40","created":1776326933235,"text":"每个步骤是一个单独的程序，每一步必须在前一步结束后才能开始，并且数据必须是完成的，以整体的方式传递。它的基本构件是独立的应用程序，连接件是某种类型的媒介。"},"children":[]}]},{"data":{"id":"dhufbz9oq0g0","created":1776326897558,"text":"管道/过滤器风格"},"children":[{"data":{"id":"dhufqmpjmns0","created":1776328045681,"text":"一个步骤的输出是另一个步骤的输入，可以并行处理；基本构件是过滤器，连接件是数据流传输管道。"},"children":[]}]}]},{"data":{"id":"dhufshmr5n40","created":1776328191356,"text":"调用/返回风格"},"children":[{"data":{"id":"dhufskvk7vc0","created":1776328198419,"text":"主/子程序风格"},"children":[]},{"data":{"id":"dhufsqtpp280","created":1776328211368,"text":"面向对象风格"},"children":[]},{"data":{"id":"dhufsu4y97s0","created":1776328218578,"text":"层次型风格"},"children":[]},{"data":{"id":"dhuft7kp80w0","created":1776328247829,"text":"客户端/服务器风格"},"children":[]}]},{"data":{"id":"dhug0ypb5vc0","created":1776328855430,"text":"以数据为中心"},"children":[{"data":{"id":"dhug11q5wdk0","created":1776328862012,"text":"仓库风格"},"children":[{"data":{"id":"dhug1etnfw80","created":1776328890521,"text":"仓库是存储和维护数据的中心场所。例如现代IDE、企业级数据管理系统"},"children":[]}]},{"data":{"id":"dhug16ag2g80","created":1776328871945,"text":"黑板风格"},"children":[]}]},{"data":{"id":"dhug2hyxmyw0","created":1776328975735,"text":"类虚拟机"},"children":[{"data":{"id":"dhug2o4yrkw0","created":1776328989160,"text":"解释器风格"},"children":[]},{"data":{"id":"dhug2t4tw1c0","created":1776329000036,"text":"规则系统风格"},"children":[]}]},{"data":{"id":"dhug2z8zcjs0","created":1776329013347,"text":"独立构件"},"children":[{"data":{"id":"dhug327n5co0","created":1776329019797,"text":"进程通信风格"},"children":[]},{"data":{"id":"dhug36oxqbc0","created":1776329029550,"text":"事件系统风格"},"children":[]}]},{"data":{"id":"dhug3kdwzps0","created":1776329059358,"text":"c2风格"},"children":[{"data":{"id":"dhug3vnqriw0","created":1776329083897,"text":"构件和连接件都有顶部和底部"},"children":[]},{"data":{"id":"dhug40p8rxc0","created":1776329094872,"text":"构件之前不允许直接连接"},"children":[]},{"data":{"id":"dhug46g63ow0","created":1776329107384,"text":"连接件可以连接任意数量的构件和其它连接件"},"children":[]},{"data":{"id":"dhug4gdeyxk0","created":1776329128985,"text":"当两个连接件直接相连时，必须一个底部连接到另一个的顶部"},"children":[]}]},{"data":{"id":"dhug4vnz9fc0","created":1776329162275,"text":"闭环控制风格"},"children":[{"data":{"id":"dhug5451y880","created":1776329180722,"text":"分支主题"},"children":[]}]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}