{"root":{"data":{"id":"dhyidqltc0o0","created":1776741738585,"text":"数据库系统"},"children":[{"data":{"id":"dhyieptui740","created":1776741815258,"text":"三级模式"},"children":[{"data":{"id":"dhyierl7gjs0","created":1776741819089,"text":"外模式"},"children":[{"data":{"id":"dhyifrlnpkg0","created":1776741897480,"text":"程序员和终端用户关注。是局部数据的逻辑结构和特征\n的描述"},"children":[]}]},{"data":{"id":"dhyieux7ja80","created":1776741826345,"text":"概念模式"},"children":[{"data":{"id":"dhyihccybso0","created":1776742021031,"text":"数据库管理员关注。是全体数据的逻辑结构和特征描述"},"children":[]}]},{"data":{"id":"dhyiew60x8o0","created":1776741829055,"text":"内模式"},"children":[{"data":{"id":"dhyihqe3kvk0","created":1776742051575,"text":"系统程序员关注。描述数据和索引存储的物理结构、路\n径等"},"children":[]}]}]},{"data":{"id":"dhyiixghf540","created":1776742145321,"text":"两级独立性"},"children":[{"data":{"id":"dhyiiz8zfi00","created":1776742149221,"text":"物理独立"},"children":[{"data":{"id":"dhyij356d0g0","created":1776742157698,"text":"应用程序和磁盘上数据库的数据相互独立"},"children":[]}]},{"data":{"id":"dhyij0sdbs00","created":1776742152570,"text":"逻辑独立"},"children":[{"data":{"id":"dhyijjagpow0","created":1776742192846,"text":"应用程序与数据库中的逻辑接口独立，逻辑接口改变，\n应用程序不需要变","layout_left_offset":{"x":8,"y":-9}},"children":[]}]}]},{"data":{"id":"dhymlhyysr40","created":1776753631142,"text":"六个阶段"},"children":[{"data":{"id":"dhymlk3ejao0","created":1776753635764,"text":"需求分析"},"children":[{"data":{"id":"dhymm1f74800","created":1776753673482,"text":"需求说明书，包括数据流图和数据字典"},"children":[]}]},{"data":{"id":"dhymllcsy7k0","created":1776753638509,"text":"概要设计"},"children":[{"data":{"id":"dhymmehxzz40","created":1776753701946,"text":"选择局部应用，逐一设计ER图并合并成为概念模型"},"children":[]}]},{"data":{"id":"dhymln7lw000","created":1776753642548,"text":"逻辑设计"},"children":[{"data":{"id":"dhymmvdsz7c0","created":1776753738701,"text":"数据模型设计，ER图转为关系模式，规范化，确定完整\n性约束，确定用户视图、反规范化设计","layout_left_offset":{"x":-101,"y":4}},"children":[]}]},{"data":{"id":"dhymlqhd2hc0","created":1776753649668,"text":"物理设计"},"children":[]},{"data":{"id":"dhymlucr9ao0","created":1776753658097,"text":"数据库实施"},"children":[]},{"data":{"id":"dhymlwjj6hs0","created":1776753662860,"text":"数据库运行和维护"},"children":[]}]},{"data":{"id":"dhymqoxhnnc0","created":1776754038111,"text":"ER图设计","image":"","imageTitle":"","imageSize":""},"children":[{"data":{"id":"dhymxfpp1tk0","created":1776754566598,"text":"局部ER图设计"},"children":[{"data":{"id":"dhymxlxpk1c0","created":1776754580143,"text":"确定局部视图的范围"},"children":[]},{"data":{"id":"dhymxp7rz1s0","created":1776754587282,"text":"识别实体及其标识，确定实体之间的联系"},"children":[]},{"data":{"id":"dhymxxn7amo0","created":1776754605629,"text":"分配实体及联系的属性"},"children":[]}]},{"data":{"id":"dhymy9vina80","created":1776754632253,"text":"合并ER图"},"children":[{"data":{"id":"dhymyf6dke00","created":1776754643794,"text":"合并"},"children":[]},{"data":{"id":"dhymygbt9400","created":1776754646299,"text":"消除冲突"},"children":[{"data":{"id":"dhymywb43ig0","created":1776754681085,"text":"属性冲突"},"children":[]},{"data":{"id":"dhymyxqffjc0","created":1776754684188,"text":"命名冲突"},"children":[]},{"data":{"id":"dhymyzujfxk0","created":1776754688790,"text":"结构冲突"},"children":[{"data":{"id":"dhymzem491s0","created":1776754720933,"text":"同一对象在不同ER图中抽象不同"},"children":[]}]}]},{"data":{"id":"dhymyi44nog0","created":1776754650188,"text":"消除冗余"},"children":[]}]}]},{"data":{"id":"dhymtsyfmqo0","created":1776754281968,"text":"其它重要概念"},"children":[{"data":{"id":"dhymtvmwp5s0","created":1776754287801,"text":"弱实体：依赖另一个实体而存在的实体，被依赖方为强\n实体（订单依赖用户，订单就是弱实体）","layout_left_offset":{"x":-12,"y":15}},"children":[]},{"data":{"id":"dhymumiixq00","created":1776754346309,"text":"弱关系：弱实体的关系"},"children":[]},{"data":{"id":"dhymutvgd9s0","created":1776754362328,"text":"不完全概化：父实体部分实例不属于任何子类别\n（职业为父实体，子实体为工程师、教师，存在\n部分职业不属于工程师和教师的类别）","layout_left_offset":{"x":-11,"y":-3}},"children":[]},{"data":{"id":"dhymw3k1jc00","created":1776754461770,"text":"完全概化"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}