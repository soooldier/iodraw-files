{"root":{"data":{"id":"dhyidqltc0o0","created":1776741738585,"text":"数据库系统"},"children":[{"data":{"id":"dhyieptui740","created":1776741815258,"text":"三级模式"},"children":[{"data":{"id":"dhyierl7gjs0","created":1776741819089,"text":"外模式"},"children":[{"data":{"id":"dhyifrlnpkg0","created":1776741897480,"text":"程序员和终端用户关注。是局部数据的逻辑结构和特征\n的描述"},"children":[]}]},{"data":{"id":"dhyieux7ja80","created":1776741826345,"text":"概念模式"},"children":[{"data":{"id":"dhyihccybso0","created":1776742021031,"text":"数据库管理员关注。是全体数据的逻辑结构和特征描述"},"children":[]}]},{"data":{"id":"dhyiew60x8o0","created":1776741829055,"text":"内模式"},"children":[{"data":{"id":"dhyihqe3kvk0","created":1776742051575,"text":"系统程序员关注。描述数据和索引存储的物理结构、路\n径等"},"children":[]}]}]},{"data":{"id":"dhyiixghf540","created":1776742145321,"text":"两级独立性"},"children":[{"data":{"id":"dhyiiz8zfi00","created":1776742149221,"text":"物理独立"},"children":[{"data":{"id":"dhyij356d0g0","created":1776742157698,"text":"应用程序和磁盘上数据库的数据相互独立"},"children":[]}]},{"data":{"id":"dhyij0sdbs00","created":1776742152570,"text":"逻辑独立"},"children":[{"data":{"id":"dhyijjagpow0","created":1776742192846,"text":"应用程序与数据库中的逻辑接口独立，逻辑接口改变，\n应用程序不需要变","layout_left_offset":{"x":8,"y":-9}},"children":[]}]}]},{"data":{"id":"dhymlhyysr40","created":1776753631142,"text":"六个阶段"},"children":[{"data":{"id":"dhymlk3ejao0","created":1776753635764,"text":"需求分析"},"children":[{"data":{"id":"dhymm1f74800","created":1776753673482,"text":"需求说明书，包括数据流图和数据字典"},"children":[]}]},{"data":{"id":"dhymllcsy7k0","created":1776753638509,"text":"概要设计"},"children":[{"data":{"id":"dhymmehxzz40","created":1776753701946,"text":"选择局部应用，逐一设计ER图并合并成为概念模型"},"children":[]}]},{"data":{"id":"dhymln7lw000","created":1776753642548,"text":"逻辑设计"},"children":[{"data":{"id":"dhymmvdsz7c0","created":1776753738701,"text":"数据模型设计，ER图转为关系模式，规范化，确定完整\n性约束，确定用户视图、反规范化设计","layout_left_offset":{"x":-101,"y":4}},"children":[]}]},{"data":{"id":"dhymlqhd2hc0","created":1776753649668,"text":"物理设计"},"children":[]},{"data