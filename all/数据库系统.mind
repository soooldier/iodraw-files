{"root":{"data":{"id":"dhyidqltc0o0","created":1776741738585,"text":"数据库系统"},"children":[{"data":{"id":"dhyieptui740","created":1776741815258,"text":"三级模式"},"children":[{"data":{"id":"dhyierl7gjs0","created":1776741819089,"text":"外模式"},"children":[{"data":{"id":"dhyifrlnpkg0","created":1776741897480,"text":"程序员和终端用户关注。是局部数据的逻辑结构和特征\n的描述"},"children":[]}]},{"data":{"id":"dhyieux7ja80","created":1776741826345,"text":"概念模式"},"children":[{"data":{"id":"dhyihccybso0","created":1776742021031,"text":"数据库管理员关注。是全体数据的逻辑结构和特征描述"},"children":[]}]},{"data":{"id":"dhyiew60x8o0","created":1776741829055,"text":"内模式"},"children":[{"data":{"id":"dhyihqe3kvk0","created":1776742051575,"text":"系统程序员关注。描述数据和索引存储的物理结构、路\n径等"},"children":[]}]}]},{"data":{"id":"dhyiixghf540","created":1776742145321,"text":"两级独立性"},"children":[{"data":{"id":"dhyiiz8zfi00","created":1776742149221,"text":"物理独立"},"children":[{"data":{"id":"dhyij356d0g0","created":1776742157698,"text":"应用程序和磁盘上数据库的数据相互独立"},"children":[]}]},{"data":{"id":"dhyij0sdbs00","created":1776742152570,"text":"逻辑独立"},"children":[{"data":{"id":"dhyijjagpow0","created":1776742192846,"text":"应用程序与数据库中的逻辑接口独立，逻辑接口改变，\n应用程序不需要变","layout_left_offset":{"x":8,"y":-9}},"children":[]}]}]},{"data":{"id":"dhymlhyysr40","created":1776753631142,"text":"六个阶段"},"children":[{"data":{"id":"dhymlk3ejao0","created":1776753635764,"text":"需求分析"},"children":[{"data":{"id":"dhymm1f74800","created":1776753673482,"text":"需求说明书，包括数据流图和数据字典"},"children":[]}]},{"data":{"id":"dhymllcsy7k0","created":1776753638509,"text":"概要设计"},"children":[{"data":{"id":"dhymmehxzz40","created":1776753701946,"text":"选择局部应用，逐一设计ER图并合并成为概念模型"},"children":[]}]},{"data":{"id":"dhymln7lw000","created":1776753642548,"text":"逻辑设计"},"children":[{"data":{"id":"dhymmvdsz7c0","created":1776753738701,"text":"数据模型设计，ER图转为关系模式，规范化，确定完整\n性约束，确定用户视图、反规范化设计","layout_left_offset":{"x":-101,"y":4}},"children":[]}]},{"data":{"id":"dhymlqhd2hc0","created":1776753649668,"text":"物理设计"},"children":[]},{"data":{"id":"dhymlucr9ao0","created":1776753658097,"text":"数据库实施"},"children":[]},{"data":{"id":"dhymlwjj6hs0","created":1776753662860,"text":"数据库运行和维护"},"children":[]}]},{"data":{"id":"dhymqoxhnnc0","created":1776754038111,"text":"ER图设计","image":"","imageTitle":"","imageSize":""},"children":[{"data":{"id":"dhymxfpp1tk0","created":1776754566598,"text":"局部ER图设计"},"children":[{"data":{"id":"dhymxlxpk1c0","created":1776754580143,"text":"确定局部视图的范围"},"children":[]},{"data":{"id":"dhymxp7rz1s0","created":1776754587282,"text":"识别实体及其标识，确定实体之间的联系"},"children":[]},{"data":{"id":"dhymxxn7amo0","created":1776754605629,"text":"分配实体及联系的属性"},"children":[]}]},{"data":{"id":"dhymy9vina80","created":1776754632253,"text":"合并ER图"},"children":[{"data":{"id":"dhymyf6dke00","created":1776754643794,"text":"合并"},"children":[]},{"data":{"id":"dhymygbt9400","created":1776754646299,"text":"消除冲突"},"children":[{"data":{"id":"dhymywb43ig0","created":1776754681085,"text":"属性冲突"},"children":[]},{"data":{"id":"dhymyxqffjc0","created":1776754684188,"text":"命名冲突"},"children":[]},{"data":{"id":"dhymyzujfxk0","created":1776754688790,"text":"结构冲突"},"children":[{"data":{"id":"dhymzem491s0","created":1776754720933,"text":"同一对象在不同ER图中抽象不同"},"children":[]}]}]},{"data":{"id":"dhymyi44nog0","created":1776754650188,"text":"消除冗余"},"children":[]}]}]},{"data":{"id":"dhymtsyfmqo0","created":1776754281968,"text":"其它重要概念"},"children":[{"data":{"id":"dhymtvmwp5s0","created":1776754287801,"text":"弱实体：依赖另一个实体而存在的实体，被依赖方为强\n实体（订单依赖用户，订单就是弱实体）","layout_left_offset":{"x":-12,"y":15}},"children":[]},{"data":{"id":"dhymumiixq00","created":1776754346309,"text":"弱关系：弱实体的关系"},"children":[]},{"data":{"id":"dhymutvgd9s0","created":1776754362328,"text":"不完全概化：父实体部分实例不属于任何子类别\n（职业为父实体，子实体为工程师、教师，存在\n部分职业不属于工程师和教师的类别）","layout_left_offset":{"x":-11,"y":-3}},"children":[]},{"data":{"id":"dhymw3k1jc00","created":1776754461770,"text":"完全概化"},"children":[]}]},{"data":{"id":"dhyp28v1hvk0","created":1776760585724,"text":"规范化"},"children":[{"data":{"id":"dhyp2bykhpk0","created":1776760592468,"text":"四大问题"},"children":[{"data":{"id":"dhyp2dngkyo0","created":1776760596150,"text":"数据冗余"},"children":[]},{"data":{"id":"dhyp2g8nb740","created":1776760601784,"text":"修改异常"},"children":[]},{"data":{"id":"dhyp2hudls00","created":1776760605275,"text":"插入异常"},"children":[]},{"data":{"id":"dhyp2joy98w0","created":1776760609300,"text":"删除异常"},"children":[]}]},{"data":{"id":"dhyp4mkst880","created":1776760772308,"text":"五大范式\n一范式，无重复；二范式，主键独；三范式，无传递；\n，BCNF主内无；四范式，多值除。","layout_left_offset":{"x":-52,"y":33}},"children":[]}]},{"data":{"id":"dhyqgjw1pso0","created":1776764527938,"text":"事务特性"},"children":[{"data":{"id":"dhyqgmd2zns0","created":1776764533321,"text":"A 原子性"},"children":[]},{"data":{"id":"dhyqgne604w0","created":1776764535564,"text":"C 一致性"},"children":[{"data":{"id":"dhyqhcfrrhs0","created":1776764590080,"text":"数据库从一个一致的状态变为另一个一致的状态。\n比如转账操作，各个账户的金额必须平衡","layout_left_offset":{"x":-5,"y":-4}},"children":[]}]},{"data":{"id":"dhyqgo2eie00","created":1776764537029,"text":"I 隔离性"},"children":[{"data":{"id":"dhyqj8uwwlc0","created":1776764739017,"text":"脏读"},"children":[]},{"data":{"id":"dhyqjdf9gm00","created":1776764748955,"text":"幻读"},"children":[]},{"data":{"id":"dhyqjhxu1g80","created":1776764758785,"text":"不可重复读"},"children":[]},{"data":{"id":"dhyqksu68rc0","created":1776764860872,"text":"写覆盖"},"children":[]}]},{"data":{"id":"dhyqgooaj1s0","created":1776764538353,"text":"D 持久性"},"children":[{"data":{"id":"dhyqi5wfguo0","created":1776764654214,"text":"事务一旦提交，便永久保存"},"children":[]}]}]},{"data":{"id":"dhyqnq5ebw00","created":1776765090113,"text":"索引优化"},"children":[{"data":{"id":"dhyqnva49i00","created":1776765101282,"text":"索引选用属性原则"},"children":[{"data":{"id":"dhyqovswftk0","created":1776765180782,"text":"选用常 查询，不常更新的列作为索引"},"children":[]},{"data":{"id":"dhyqpfpa7u00","created":1776765224099,"text":"不选用区分度低的列作为索引"},"children":[]}]},{"data":{"id":"dhyqojulq200","created":1776765154764,"text":"索引数量"},"children":[{"data":{"id":"dhyqpnx8z2g0","created":1776765241995,"text":"数量太多影响插入性能"},"children":[]}]},{"data":{"id":"dhyqollpjzk0","created":1776765158579,"text":"索引优化策略"},"children":[{"data":{"id":"dhyqqfbh4mg0","created":1776765301628,"text":"分析查询频度，找出使用最多的来进行优化"},"children":[]}]},{"data":{"id":"dhyqop7tmhk0","created":1776765166447,"text":"小数据量关系处理"},"children":[{"data":{"id":"dhyqq43p92o0","created":1776765277214,"text":"小表无需索引"},"children":[]}]}]},{"data":{"id":"dhyqrj9qkyo0","created":1776765388595,"text":"完整性约束"},"children":[{"data":{"id":"dhyqrnczbwg0","created":1776765397498,"text":"实体完整性约束"},"children":[{"data":{"id":"dhyqsa9s2yg0","created":1776765447370,"text":"主码不能为空"},"children":[]}]},{"data":{"id":"dhyqrq1tgwg0","created":1776765403353,"text":"参照完整性约束"},"children":[{"data":{"id":"dhyqslmfgow0","created":1776765472080,"text":"外键必须有效"},"children":[]}]},{"data":{"id":"dhyqs20vly80","created":1776765429418,"text":"用户定义完整性约束"},"children":[{"data":{"id":"dhyqsso3igo0","created":1776765487418,"text":"字段取值范围必须有效"},"children":[]}]}]},{"data":{"id":"dhyqtx4uriw0","created":1776765575502,"text":"触发器"},"children":[{"data":{"id":"dhyqv5dgg2w0","created":1776765671801,"text":"CREATE TRIGGER before_insert_user\n BEFORE INSERT ON users\nFOR EACH ROW\nBEGIN\nSET NEW.create_time = NOW();\nEND\n// NEW.column 和 OLD.column","layout_left_offset":{"x":-41,"y":26}},"children":[]}]},{"data":{"id":"dhyqwp6kdmo0","created":1776765793284,"text":"备份"},"children":[{"data":{"id":"dhyqwrip9ls0","created":1776765798372,"text":"物理备份"},"children":[]},{"data":{"id":"dhyqwtxywmg0","created":1776765803648,"text":"逻辑备份"},"children":[]},{"data":{"id":"dhyqwvef8o80","created":1776765806820,"text":"全量备份"},"children":[]},{"data":{"id":"dhyqwxqt1sg0","created":1776765811922,"text":"增量备份"},"children":[]},{"data":{"id":"dhyqx0jnve80","created":1776765818021,"text":"差异备份"},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}